<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:context=".MainActivity">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Native Bridge Results"
            android:textColor="#9AA0B0"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingBottom="12dp"/>

        <!-- Card 1 : Fingerprint -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_blue"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NATIVE FINGERPRINT"
                android:textColor="#1565C0"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="10dp"/>

            <TextView
                android:id="@+id/tvFingerprint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#0D47A1"
                android:textSize="14sp"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓  JNI call successful"
                android:textColor="#1976D2"
                android:textSize="11sp"
                android:paddingTop="8dp"/>
        </LinearLayout>

        <!-- Card 2 : XOR Cipher -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_amber"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="XOR CIPHER"
                android:textColor="#E65100"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="10dp"/>

            <TextView
                android:id="@+id/tvXor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#BF360C"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="5dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓  Reversible · overflow safe"
                android:textColor="#E65100"
                android:textSize="11sp"
                android:paddingTop="8dp"/>
        </LinearLayout>

        <!-- Card 3 : Caesar Cipher -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_purple"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔑  CAESAR CIPHER"
                android:textColor="#6A1B9A"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="10dp"/>

            <TextView
                android:id="@+id/tvCaesar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#4A148C"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="5dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓  Negative shift supported"
                android:textColor="#6A1B9A"
                android:textSize="11sp"
                android:paddingTop="8dp"/>
        </LinearLayout>

        <!-- Card 4 : Sum Array -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_green"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SUM ARRAY"
                android:textColor="#1B5E20"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingBottom="10dp"/>

            <TextView
                android:id="@+id/tvArray"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="5dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓  Overflow check · null safe"
                android:textColor="#1B5E20"
                android:textSize="11sp"
                android:paddingTop="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>